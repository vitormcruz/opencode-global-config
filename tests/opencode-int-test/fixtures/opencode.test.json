{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@slkiser/opencode-quota"],
  "mcp": {
    "crawl4ai": {
      "type": "remote",
      "url": "http://127.0.0.1:11235/mcp/sse",
      "enabled": true
    }
  },
  "agent": {
    "plan": {
      "model": "opencode/big-pickle"
    },
    "build": {
      "model": "opencode/big-pickle"
    },
    "aws-analista": {
      "permission": {
        "skill": {
          "aws-*": "allow"
        }
      }
    }
  },
  "permission": {
    "skill": {
      "aws-*": "deny"
    }
  }
}
