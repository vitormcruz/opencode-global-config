#!/usr/bin/env bash
# sync - Importa/atualiza arquivos do upstream ckelsoe/claude-skill-prompt-architect
# Uso: ./scripts/prompt-improver/sync [--yes] [--check-only]
set -euo pipefail

UPSTREAM_REPO="https://github.com/ckelsoe/claude-skill-prompt-architect.git"
UPSTREAM_BRANCH="main"
SKILL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../skills/prompt-improver" && pwd -P)"
TMPDIR_BASE="${TMPDIR:-/tmp}"
TMPDIR_WORK=""

assume_yes=0
check_only=0

usage() {
  cat <<'EOF'
sync - Sincroniza skill prompt-improver com o upstream

Uso:
  ./scripts/prompt-improver/sync [--yes] [--check-only]

Opcoes:
  --yes          Nao pede confirmacao
  --check-only   Apenas verifica se ha atualizacoes (nao copia nada)
  --help         Mostra esta ajuda

O que faz:
  1. Clona o repo upstream em diretorio temporario
  2. Valida que a licenca ainda e MIT (aborta se nao for)
  3. Copia references/, assets/, scripts/ e LICENSE
  4. Registra metadados em UPSTREAM.md
  5. NAO sobrescreve SKILL.md (versao adaptada)
EOF
}

cleanup() {
  if [ -n "$TMPDIR_WORK" ] && [ -d "$TMPDIR_WORK" ]; then
    rm -rf "$TMPDIR_WORK"
  fi
}
trap cleanup EXIT

die() { echo "ERRO: $*" >&2; exit 1; }
info() { echo "[sync] $*"; }

# --- Parse args ---
while [ $# -gt 0 ]; do
  case "$1" in
    --yes) assume_yes=1 ;;
    --check-only) check_only=1 ;;
    --help|-h) usage; exit 0 ;;
    *) echo "Opcao desconhecida: $1" >&2; usage >&2; exit 2 ;;
  esac
  shift
done

# --- Verifica dependencias ---
command -v git >/dev/null 2>&1 || die "git nao encontrado"

# --- Confirma acao ---
if [ "$check_only" -eq 0 ] && [ "$assume_yes" -eq 0 ]; then
  echo "Este script ira sincronizar os arquivos de framework do upstream:"
  echo "  $UPSTREAM_REPO"
  echo "Destino: $SKILL_DIR"
  echo "O SKILL.md adaptado NAO sera sobrescrito."
  echo ""
  read -r -p "Continuar? [s/N] " resp
  case "$resp" in
    [sS]*) ;;
    *) echo "Cancelado."; exit 0 ;;
  esac
fi

# --- Clona upstream ---
TMPDIR_WORK="$(mktemp -d "${TMPDIR_BASE}/prompt-improver-sync-XXXXXX")"
info "Clonando upstream em $TMPDIR_WORK ..."
# GIT_SSL_NO_VERIFY necessario em alguns ambientes WSL com CA customizado
GIT_SSL_NO_VERIFY=1 git clone --depth=1 --branch "$UPSTREAM_BRANCH" "$UPSTREAM_REPO" "$TMPDIR_WORK/upstream" \
  2>&1 | sed 's/^/  [git] /'

UPSTREAM_DIR="$TMPDIR_WORK/upstream"

# --- Captura metadados ---
UPSTREAM_COMMIT=$(git -C "$UPSTREAM_DIR" rev-parse HEAD)
UPSTREAM_COMMIT_SHORT=$(git -C "$UPSTREAM_DIR" rev-parse --short HEAD)
UPSTREAM_DATE=$(git -C "$UPSTREAM_DIR" log -1 --format="%ci")
UPSTREAM_VERSION=""
if [ -f "$UPSTREAM_DIR/package.json" ]; then
  UPSTREAM_VERSION=$(grep '"version"' "$UPSTREAM_DIR/package.json" | head -1 | sed 's/.*"version": *"\([^"]*\)".*/\1/')
fi

info "Upstream: commit $UPSTREAM_COMMIT_SHORT | versao $UPSTREAM_VERSION | $UPSTREAM_DATE"

# --- Valida licenca ---
info "Validando licenca ..."
LICENSE_FILE="$UPSTREAM_DIR/LICENSE"
[ -f "$LICENSE_FILE" ] || die "LICENSE nao encontrado no upstream"

if ! grep -qi "MIT License" "$LICENSE_FILE" && ! grep -qi "MIT" "$LICENSE_FILE"; then
  die "Licenca NAO e MIT. Aborting. Verifique manualmente: $LICENSE_FILE"
fi
info "Licenca: MIT confirmada"

# --- Se check-only, para aqui ---
if [ "$check_only" -eq 1 ]; then
  UPSTREAM_MD="$SKILL_DIR/UPSTREAM.md"
  if [ -f "$UPSTREAM_MD" ]; then
    CURRENT_COMMIT=$(grep "^commit:" "$UPSTREAM_MD" 2>/dev/null | awk '{print $2}' || echo "desconhecido")
    if [ "$CURRENT_COMMIT" = "$UPSTREAM_COMMIT" ]; then
      info "Ja esta atualizado (commit $UPSTREAM_COMMIT_SHORT)"
    else
      info "Atualizacao disponivel: local=$CURRENT_COMMIT upstream=$UPSTREAM_COMMIT_SHORT"
    fi
  else
    info "UPSTREAM.md nao encontrado - sync inicial necessario"
  fi
  exit 0
fi

# --- Copia arquivos ---
info "Copiando arquivos do upstream ..."

# references/frameworks/
SRC_REFS="$UPSTREAM_DIR/prompt-architect/references"
DST_REFS="$SKILL_DIR/references"
if [ -d "$SRC_REFS" ]; then
  rm -rf "$DST_REFS"
  cp -r "$SRC_REFS" "$DST_REFS"
  COUNT_REFS=$(find "$DST_REFS" -name "*.md" | wc -l | tr -d ' ')
  info "  references/: $COUNT_REFS arquivos .md copiados"
else
  info "  AVISO: references/ nao encontrado no upstream"
fi

# assets/templates/
SRC_ASSETS="$UPSTREAM_DIR/prompt-architect/assets"
DST_ASSETS="$SKILL_DIR/assets"
if [ -d "$SRC_ASSETS" ]; then
  rm -rf "$DST_ASSETS"
  cp -r "$SRC_ASSETS" "$DST_ASSETS"
  COUNT_ASSETS=$(find "$DST_ASSETS" -name "*.txt" | wc -l | tr -d ' ')
  info "  assets/: $COUNT_ASSETS arquivos .txt copiados"
else
  info "  AVISO: assets/ nao encontrado no upstream"
fi

# scripts Python
SRC_PY="$UPSTREAM_DIR/prompt-architect/scripts"
DST_PY="$SKILL_DIR/scripts"
if [ -d "$SRC_PY" ]; then
  rm -rf "$DST_PY"
  cp -r "$SRC_PY" "$DST_PY"
  COUNT_PY=$(find "$DST_PY" -name "*.py" | wc -l | tr -d ' ')
  info "  scripts/: $COUNT_PY scripts Python copiados"
else
  info "  AVISO: scripts/ nao encontrado no upstream"
fi

# LICENSE
cp "$LICENSE_FILE" "$SKILL_DIR/LICENSE"
info "  LICENSE copiado"

# --- Atualiza UPSTREAM.md ---
info "Atualizando UPSTREAM.md ..."
SYNC_DATE=$(date -u +"%Y-%m-%d %H:%M UTC")
cat > "$SKILL_DIR/UPSTREAM.md" <<EOF
# Metadados do Upstream

repositorio: https://github.com/ckelsoe/claude-skill-prompt-architect
branch: $UPSTREAM_BRANCH
versao: $UPSTREAM_VERSION
commit: $UPSTREAM_COMMIT
data_commit: $UPSTREAM_DATE
sincronizado_em: $SYNC_DATE

## Arquivos sincronizados

- references/frameworks/  ($COUNT_REFS arquivos)
- assets/templates/       ($COUNT_ASSETS arquivos)
- scripts/                ($COUNT_PY scripts Python)
- LICENSE

## Nao sincronizado

- SKILL.md  (versao adaptada para OpenCode - mantenha manualmente)

## Como atualizar

Execute a partir da raiz do repo:

    bash scripts/prompt-improver/sync

Para verificar se ha atualizacoes sem sincronizar:

    bash scripts/prompt-improver/sync --check-only

## Licenca

MIT License - Copyright (c) 2025 prompt-architect contributors
Autoria original: Charles Kelsoe <charles@kelsoe.com>
EOF

info "Sincronizacao concluida."
info "  Upstream: $UPSTREAM_VERSION @ $UPSTREAM_COMMIT_SHORT"
info "  Skill:    $SKILL_DIR"
info ""
info "SKILL.md nao foi alterado. Se houver mudancas relevantes no upstream,"
info "revise o diff e atualize manualmente o SKILL.md se necessario."
