#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
opencode-link

Cria links simbolicos em ~/.config/opencode apontando para este repo.

Uso:
  ./scripts/opencode-link [--yes]

Opcoes:
  --yes      Nao pergunta confirmacao
  --help     Mostra esta ajuda
EOF
}

assume_yes=0

while [ $# -gt 0 ]; do
  case "$1" in
    --yes) assume_yes=1 ;;
    --help|-h) usage; exit 0 ;;
    *) echo "Opcao desconhecida: $1" >&2; usage >&2; exit 2 ;;
  esac
  shift
done

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
repo_root="$(cd "${script_dir}/.." && pwd -P)"

opencode_dir="${HOME}/.config/opencode"
timestamp="$(date +%Y%m%d-%H%M%S)"
backup_dir="${HOME}/.config/opencode-backup/${timestamp}"

say() { printf '%s\n' "$*"; }

resolve_path() {
  if command -v realpath >/dev/null 2>&1; then
    realpath -m "$1" 2>/dev/null || true
    return 0
  fi
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$1" <<'PY' 2>/dev/null || true
import os,sys
print(os.path.realpath(sys.argv[1]))
PY
    return 0
  fi
  printf '%s\n' "$1"
}

current_target() {
  # Retorna o caminho resolvido para onde o symlink aponta.
  # Se nao for symlink, retorna string vazia.
  local dest="$1"
  if [ ! -L "$dest" ]; then
    printf '%s' ""
    return 0
  fi

  local t
  t="$(readlink "$dest" 2>/dev/null || true)"
  if [ -z "$t" ]; then
    printf '%s' ""
    return 0
  fi

  if [ "${t#/}" = "$t" ]; then
    t="$(dirname "$dest")/$t"
  fi

  resolve_path "$t"
}

ensure_dir() {
  mkdir -p "$1"
}

backup_if_exists() {
  local dest="$1"

  if [ ! -e "$dest" ] && [ ! -L "$dest" ]; then
    return 0
  fi

  ensure_dir "$backup_dir"

  local base
  base="$backup_dir/$(basename "$dest")"

  local out="$base"
  if [ -e "$out" ] || [ -L "$out" ]; then
    local i=1
    while [ $i -lt 100 ]; do
      if [ ! -e "${base}.${i}" ] && [ ! -L "${base}.${i}" ]; then
        out="${base}.${i}"
        break
      fi
      i=$((i + 1))
    done
  fi

  mv "$dest" "$out"
}

link_one() {
  local source="$1"
  local dest="$2"

  local src_abs
  src_abs="$(resolve_path "$source")"
  if [ -z "$src_abs" ]; then src_abs="$source"; fi

  local cur
  cur="$(current_target "$dest")"
  local src_res
  src_res="$(resolve_path "$src_abs")"

  if [ -n "$cur" ] && [ -n "$src_res" ] && [ "$cur" = "$src_res" ]; then
    return 0
  fi

  backup_if_exists "$dest"
  ln -s "$src_abs" "$dest"
}

confirm() {
  if [ "$assume_yes" -eq 1 ]; then
    return 0
  fi

  if ! [ -t 0 ] || ! [ -t 1 ]; then
    echo "Sem TTY para confirmacao; use --yes" >&2
    exit 2
  fi

  printf 'Aplicar estas alteracoes? [y/N] '
  read -r ans || true
  case "$ans" in y|Y|yes|YES) return 0 ;; esac
  say "Cancelado."
  exit 1
}

status_line() {
  local source="$1"
  local dest="$2"

  local src_abs
  src_abs="$(resolve_path "$source")"
  if [ -z "$src_abs" ]; then src_abs="$source"; fi

  local cur
  cur="$(current_target "$dest")"
  local src_res
  src_res="$(resolve_path "$src_abs")"

  if [ -n "$cur" ] && [ -n "$src_res" ] && [ "$cur" = "$src_res" ]; then
    say "OK    $dest"
    return 0
  fi

  if [ -e "$dest" ] || [ -L "$dest" ]; then
    say "BK    $dest"
    say "LN    $dest -> $src_abs"
    return 0
  fi

  say "LN    $dest -> $src_abs"
}

plan() {
  say "Repo:   $repo_root"
  say "Destino: $opencode_dir"
  say "Backup: $backup_dir"
  say "Plano:"

  if [ ! -d "$opencode_dir" ]; then
    say "MKDIR $opencode_dir"
  fi

  status_line "$repo_root/AGENTS.md" "$opencode_dir/AGENTS.md"
  status_line "$repo_root/agents" "$opencode_dir/agents"
  status_line "$repo_root/opencode.json" "$opencode_dir/opencode.json"
  status_line "$repo_root/skills" "$opencode_dir/skills"
  status_line "$repo_root/scripts" "$opencode_dir/scripts"
}

apply() {
  say "Aplicando..."

  ensure_dir "$opencode_dir"

  link_one "$repo_root/AGENTS.md" "$opencode_dir/AGENTS.md"
  link_one "$repo_root/agents" "$opencode_dir/agents"
  link_one "$repo_root/opencode.json" "$opencode_dir/opencode.json"
  link_one "$repo_root/skills" "$opencode_dir/skills"
  link_one "$repo_root/scripts" "$opencode_dir/scripts"

  say "Pronto."
}

confirm_import() {
  if [ "$assume_yes" -eq 1 ]; then
    return 1
  fi
  if ! [ -t 0 ] || ! [ -t 1 ]; then
    return 1
  fi
  printf 'Agregar/importar diferencas de %s para este repo antes de linkar? [y/N] ' "$opencode_dir"
  read -r ans || true
  case "$ans" in y|Y|yes|YES) return 0 ;; esac
  return 1
}

import_global_into_repo() {
  local incoming_dir="$repo_root/incoming-global/$timestamp"
  local tmp_dir
  tmp_dir="$(mktemp -d /tmp/opencode-global-XXXXXX)"

  say "Importando diferencas do global para o repo..."
  ensure_dir "$incoming_dir"

  # Materializa o global (dereferenciando symlinks) para facilitar diff.
  if command -v tar >/dev/null 2>&1; then
    (cd "$opencode_dir" && tar -chf - .) | (cd "$tmp_dir" && tar -xf -)
  else
    cp -aL "$opencode_dir/." "$tmp_dir/"
  fi

  should_skip() {
    case "$1" in
      .cache/*|*/.cache/*|cache/*|*/cache/*|tmp/*|*/tmp/*|logs/*|*/logs/*) return 0 ;;
      *.swp|*~|.DS_Store|Thumbs.db) return 0 ;;
    esac
    return 1
  }

  # Cria dirs primeiro.
  while IFS= read -r -d '' p; do
    local rel
    rel="${p#"$tmp_dir"/}"
    if [ -z "$rel" ] || [ "$rel" = "." ]; then continue; fi
    if should_skip "$rel"; then continue; fi

    local dest
    dest="$repo_root/$rel"
    if [ -e "$dest" ] && [ ! -d "$dest" ]; then
      ensure_dir "$(dirname "$incoming_dir/$rel")"
      cp -a "$p" "$incoming_dir/$rel.from-global"
      continue
    fi
    ensure_dir "$dest"
  done < <(find "$tmp_dir" -type d -print0)

  # Copia arquivos.
  while IFS= read -r -d '' p; do
    local rel
    rel="${p#"$tmp_dir"/}"
    if [ -z "$rel" ] || [ "$rel" = "." ]; then continue; fi
    if should_skip "$rel"; then continue; fi

    local dest
    dest="$repo_root/$rel"
    ensure_dir "$(dirname "$dest")"

    if [ ! -e "$dest" ]; then
      cp -a "$p" "$dest"
      continue
    fi

    if [ -f "$dest" ] && cmp -s "$p" "$dest"; then
      continue
    fi

    ensure_dir "$(dirname "$incoming_dir/$rel")"
    cp -a "$p" "$incoming_dir/$rel.from-global"
  done < <(find "$tmp_dir" -type f -print0)

  rm -rf "$tmp_dir"

  say "Import concluido. Revise: $incoming_dir (conflitos)"
  say "Sugestao: confira segredos e depois rode 'git status' e considere commitar."
}

main() {
  say "Repo:   $repo_root"
  say "Destino: $opencode_dir"

  local global_exists=0
  if [ -e "$opencode_dir" ] || [ -L "$opencode_dir" ]; then
    global_exists=1
  fi

  # Se ja estiver apontando para este repo, nao faz nada.
  if [ -d "$opencode_dir" ] && \
     [ "$(current_target "$opencode_dir/AGENTS.md")" = "$(resolve_path "$repo_root/AGENTS.md")" ] && \
     [ "$(current_target "$opencode_dir/opencode.json")" = "$(resolve_path "$repo_root/opencode.json")" ] && \
     [ "$(current_target "$opencode_dir/scripts")" = "$(resolve_path "$repo_root/scripts")" ]; then
    say "Nada a fazer (global ja aponta para este repo)."
    return 0
  fi

  timestamp="$(date +%Y%m%d-%H%M%S)"
  backup_dir="${HOME}/.config/opencode-backup/${timestamp}"

  if [ "$global_exists" -eq 1 ] && [ -d "$opencode_dir" ] && [ "$(ls -A "$opencode_dir" 2>/dev/null || true)" != "" ]; then
    if confirm_import; then
      import_global_into_repo
    fi
  fi

  # Mostra o plano de linkagem.
  say "Backup: $backup_dir"
  say "Plano:"
  if [ "$global_exists" -eq 1 ]; then
    say "BK    $opencode_dir -> $backup_dir/opencode"
  fi
  say "MKDIR $opencode_dir"
  say "LN    $opencode_dir/* -> $repo_root/* (exceto README.md e incoming-global/)"

  if [ "$assume_yes" -eq 0 ]; then
    confirm
  fi

  # Backup do global (sempre que existir) e cria links.
  if [ "$global_exists" -eq 1 ]; then
    ensure_dir "$backup_dir"
    mv "$opencode_dir" "$backup_dir/opencode"
  fi

  ensure_dir "$opencode_dir"

  for item in "$repo_root"/*; do
    base="$(basename "$item")"
    case "$base" in
      README.md|incoming-global) continue ;;
    esac
    ln -s "$(resolve_path "$item")" "$opencode_dir/$base"
  done

  say "Pronto."
}

main
